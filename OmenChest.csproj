<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net462</TargetFramework>
    <AssemblyName>ChzzkSkul</AssemblyName>
    <Description>ChzzkSkul</Description>
    <Version>1.0.8</Version>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>
    <RestoreAdditionalProjectSources>
      https://api.nuget.org/v3/index.json;
      https://nuget.bepinex.dev/v3/index.json;
      https://nuget.samboy.dev/v3/index.json
    </RestoreAdditionalProjectSources>
    <RootNamespace>ChzzkSkul</RootNamespace>
    <DebugSymbols>false</DebugSymbols>
    <DebugType>None</DebugType>
    <!-- BepInEx.PluginInfoProps가 AssemblyInfo를 자동 생성하므로 SDK 자동 생성 비활성화 -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <NoWarn>$(NoWarn);CS0436</NoWarn>
  </PropertyGroup>

  <!-- TestConsoleBuild는 별도 프로젝트이므로 컴파일 대상에서 제외 -->
  <!-- recover_project는 복원 백업 폴더이므로 컴파일 대상에서 제외 -->
  <ItemGroup>
    <Compile Remove="TestConsoleBuild\**" />
    <None Remove="TestConsoleBuild\**" />
    <Content Remove="TestConsoleBuild\**" />
    <EmbeddedResource Remove="TestConsoleBuild\**" />
    <Compile Remove="recover_project\**" />
    <None Remove="recover_project\**" />
    <Content Remove="recover_project\**" />
    <EmbeddedResource Remove="recover_project\**" />
  </ItemGroup>

  <PropertyGroup>
    <SkulRoot Condition="'$(OS)' == 'Windows_NT' And Exists('$(PROGRAMFILES)\Steam\steamapps\common\Skul\Skul.exe')">$(PROGRAMFILES)\Steam\steamapps\common\Skul</SkulRoot>
    <SkulRoot Condition="'$(OS)' == 'Windows_NT' And Exists('$(MSBuildProgramFiles32)\Steam\steamapps\common\Skul\Skul.exe')">$(MSBuildProgramFiles32)\Steam\steamapps\common\Skul</SkulRoot>
    <SkulRoot Condition="'$(OS)' == 'Windows_NT' And Exists('C:\Program Files (x86)\Steam\steamapps\common\Skul')">C:\Program Files (x86)\Steam\steamapps\common\Skul</SkulRoot>
    <ProduceReferenceAssembly>False</ProduceReferenceAssembly>
  </PropertyGroup>

