    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="UniTask" Version="2.5.10" />
    <PackageReference Include="UnityEngine.Modules" Version="2021.3.33" IncludeAssets="compile" />
  </ItemGroup>
  
