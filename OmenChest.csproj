  <Target Name="CopyToPlugins" AfterTargets="Build">
    <PropertyGroup>
      <TSProfilesDir>C:\Users\jimin\AppData\Roaming\Thunderstore Mod Manager\DataFolder\SkulTheHeroSlayer\profiles</TSProfilesDir>
    </PropertyGroup>

    <!-- Steam 기본 폴더 배포 -->
    <Message Text="[Auto-Deploy] Copying output DLL to Steam Skul..." Importance="high" Condition="'$(SkulRoot)' != ''" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(SkulRoot)\BepInEx\plugins\" Condition="'$(SkulRoot)' != ''" />

    <!-- Thunderstore Mod Manager 모든 프로필의 기존 OmenChestWorld.dll 및 ChzzkSkul.dll 찾아서 업데이트 -->
    <ItemGroup>
      <TSProfilesOld Include="$(TSProfilesDir)\**\OmenChestWorld.dll" />
      <TSProfilesNew Include="$(TSProfilesDir)\**\ChzzkSkul.dll" />
    </ItemGroup>

    <Message Text="[Auto-Deploy] Updating Thunderstore Profile DLL (Legacy): %(TSProfilesOld.Identity)" Importance="high" Condition="Exists('$(TSProfilesDir)') And '@(TSProfilesOld)' != ''" />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="%(TSProfilesOld.Identity)" Condition="Exists('$(TSProfilesDir)') And '@(TSProfilesOld)' != ''" />

    <Message Text="[Auto-Deploy] Updating Thunderstore Profile DLL (New): %(TSProfilesNew.Identity)" Importance="high" Condition="Exists('$(TSProfilesDir)') And '@(TSProfilesNew)' != ''" />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="%(TSProfilesNew.Identity)" Condition="Exists('$(TSProfilesDir)') And '@(TSProfilesNew)' != ''" />
  </Target>
